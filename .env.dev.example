# Core paths
SHARED_CONTRACTS_DIR=/workspace/shared-contracts
SKILL_FACTORY_DIR=/workspace/skill-factory
SKILL_TOOL_SPECS_DIR=/workspace/skill-factory/tools/v1
MEMORY_BANK_FILE=/workspace/shared-contracts/memory-bank.v1.json
AGENT_FACTORY_MODE=serve
EMPLOYEE_ID=joanne

# Gemini (default provider)
INFERENCE_PROVIDER=gemini
# Prefer preview Flash for latency/cost; use gemini-2.5-pro only if you need Pro-only behavior. Google Search grounding works with Flash + GEMINI_ENABLE_WEB_RESEARCH=true.
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_API_KEY=replace-with-dev-default-key
BYOK_GEMINI_API_KEY=
GEMINI_ENABLE_WEB_RESEARCH=true
# Optional: raise if you see empty replies with finishReason=MAX_TOKENS (thinking/search can consume budget before visible text).
# GEMINI_CONV_MAX_OUTPUT_TOKENS=768
# GEMINI_CONV_MAX_OUTPUT_TOKENS_WITH_SEARCH=4096

# Orchestrator + backend endpoints
ORCHESTRATOR_NATS_URL=nats://nats:4222
MAKEACOMPANY_BACKEND_BASE_URL=http://host.docker.internal:8090

# Core compose ports for makeacompany + admin authority
AGENT_FACTORY_ADMIN_PORT=8091
MAKEACOMPANY_BACKEND_PORT=8090
MAKEACOMPANY_FRONTEND_PORT=3000
MAKEACOMPANY_APP_BASE_URL=http://localhost:3000
AGENT_FACTORY_ADMIN_BASE_URL=http://agent-factory-admin:8091
AGENT_FACTORY_ADMIN_TOKEN=
BACKEND_INTERNAL_API_BASE_URL=http://makeacompany-backend:8080
NEXT_PUBLIC_BACKEND_API_BASE_URL=http://localhost:8090
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared runtime wiring
NATS_URL=nats://nats:4222
NATS_STREAM=SLACK_WORK
NATS_FETCH_BATCH=8
NATS_FETCH_MAX_WAIT_MS=5000
ORCHESTRATOR_INGRESS_WORKERS=4
# Remote handoff (Joanne → Ross on separate pods): Redis stores continuation payload; omit REDIS_URL for in-process handoff only.
# With docker-compose.core.yml use the bundled redis service:
REDIS_URL=redis://redis:6379/0
HANDOFF_REDIS_TTL_SEC=86400
HANDOFF_REDIS_KEY_PREFIX=
BACKEND_INTERNAL_SERVICE_TOKEN=replace-with-dev-internal-token
# Cold-start loops (docker-compose.core.yml profile local): snapshot cron mimic + channel-knowledge refresh
SNAPSHOT_BOOT_DELAY_SEC=25
SNAPSHOT_REFRESH_INTERVAL_SEC=900
# Default matches rancher-admin channel-scraper image pin; override if you need a newer employee-factory tag.
CHANNEL_KNOWLEDGE_REFRESH_IMAGE=geeemoney/employee-factory:0.15.23
CHANNEL_KNOWLEDGE_REFRESH_INTERVAL_SEC=180
# Optional comma-separated Slack channel IDs to limit harvest churn locally (empty = registry / bot membership behavior per binary).
CHANNEL_KNOWLEDGE_CHANNEL_IDS=
# Optional OpenRouter key for post-digest company pulse inside channel-knowledge-refresh (same optional path as prod CronJob).
JOANNE_OR_KEY=

CAPABILITY_CATALOG_READ_TOKEN=
REQUIRE_CAPABILITY_CATALOG_READ_TOKEN=false
COMPANY_CHANNELS_REDIS_URL=
COMPANY_CHANNELS_REDIS_KEY=agent-factory:company_channels
CAPABILITY_ROUTING_EVENTS_REDIS_KEY=agent-factory:capability_routing_events
ADMIN_CATALOG_TOKEN=
ADMIN_SIGN_IN_ALLOWLIST=
ADMIN_SESSION_TTL_SEC=259200
SLACK_ORCHESTRATOR_CAPABILITY_CATALOG_URL=http://slack-orchestrator:8080/v1/public/capability-catalog
ORCHESTRATOR_DEBUG_BASE_URL=http://slack-orchestrator:8080
ORCHESTRATOR_DEBUG_TOKEN=
ONBOARDING_CHANNEL=
# Optional: warm Slack user snapshot + user_by_slack index after posting #humans welcome (same bearer as BACKEND_INTERNAL_SERVICE_TOKEN).
# SLACK_USERS_SNAPSHOT_REFRESH_URL=http://host.docker.internal:${MAKEACOMPANY_BACKEND_PORT:-8090}/v1/internal/refresh-slack-users-snapshot
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
RESEND_API_KEY=
PORTAL_AUTH_EMAIL_FROM=
# Resend template slugs/ids (see Resend Templates dashboard)
RESEND_MAGIC_LINK_TEMPLATE_ID=account-login
RESEND_CHECKOUT_WELCOME_TEMPLATE_ID=welcome-email
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_BASE_PLAN=
STRIPE_PRICE_ID_WAITLIST_DEPOSIT=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=
JOANNE_NATS_DURABLE_NAME=agent-factory-joanne
ROSS_NATS_DURABLE_NAME=agent-factory-ross
ALEX_NATS_DURABLE_NAME=agent-factory-alex
GARTH_NATS_DURABLE_NAME=agent-factory-garth
TIM_NATS_DURABLE_NAME=agent-factory-tim
ANNA_NATS_DURABLE_NAME=agent-factory-anna

# Orchestrator app tokens (slack-orchestrator service).
# Same ORCHESTRATOR_SLACK_BOT_TOKEN is passed to makeacompany-backend as SLACK_BOT_TOKEN so /admin Slack Users (live)
# and internal refresh-slack-users populate makeacompany:user_profile slack_user_id + user_by_slack index.
ORCHESTRATOR_SLACK_BOT_TOKEN=replace-with-orchestrator-bot-token
ORCHESTRATOR_SLACK_APP_TOKEN=replace-with-orchestrator-app-token
# Map Slack user ids for squad bots (extend when adding agents): alex,garth,tim,anna, …
MULTIAGENT_BOT_USER_IDS=joanne=UXXXXXX,ross=UYYYYYY
ORCHESTRATOR_TOOL_INTENT_ROUTING_ENABLED=true
ORCHESTRATOR_SEMANTIC_TOOL_ROUTING_ENABLED=true
ORCHESTRATOR_SEMANTIC_TOOL_ROUTING_SHADOW=false
ORCHESTRATOR_SEMANTIC_TOOL_MIN_CONFIDENCE=0.20
ORCHESTRATOR_SEMANTIC_TOOL_MIN_MARGIN=0.03
ORCHESTRATOR_SEMANTIC_FALLBACK_TO_TIER1=false

# Employee app tokens (agent-factory instances)
JOANNE_SLACK_BOT_TOKEN=replace-with-joanne-bot-token
JOANNE_SLACK_APP_TOKEN=replace-with-joanne-app-token
# Duplicate into agent-joanne compose so handoff replies (e.g. create-issue) can post as Ross.
ROSS_SLACK_BOT_TOKEN=replace-with-ross-bot-token
ROSS_SLACK_APP_TOKEN=replace-with-ross-app-token
ALEX_SLACK_BOT_TOKEN=replace-with-alex-bot-token
ALEX_SLACK_APP_TOKEN=replace-with-alex-app-token
GARTH_SLACK_BOT_TOKEN=replace-with-garth-bot-token
GARTH_SLACK_APP_TOKEN=replace-with-garth-app-token
TIM_SLACK_BOT_TOKEN=replace-with-tim-bot-token
TIM_SLACK_APP_TOKEN=replace-with-tim-app-token
ANNA_SLACK_BOT_TOKEN=replace-with-anna-bot-token
ANNA_SLACK_APP_TOKEN=replace-with-anna-app-token

# Shared signing secret (or per-app if you split it)
SLACK_SIGNING_SECRET=replace-with-signing-secret

# GitHub — create-issue / read-github* (fine-grained or classic PAT; org PAT slot removed).
# Resolution order per employee: ROSS_GITHUB_TOKEN, ROSS_PERSONAL_GH_TOKEN; then global
# GITHUB_TOKEN, PERSONAL_GH_TOKEN. To default org/repo inventory to an organization namespace,
# set GITHUB_OWNER / GITHUB_OWNER_SCOPE=org (optional).
# Internal handoff (Joanne → Ross): inject Ross keys into agent-joanne too — see docker-compose.
# Optional: GITHUB_OWNER / GITHUB_OWNER_SCOPE=user|org (unset = authenticated user's login via GET /user; inventory uses GitHub list APIs, not implicit org guessing).
# Optional: short-lived GitHub follow-up stickiness (seconds) for thread replies that
# omit explicit tool intent after a successful read-github call in the same thread.
GITHUB_FOLLOWUP_STICKY_WINDOW_SEC=480
GITHUB_OWNER_SCOPE=
GITHUB_TOKEN=
PERSONAL_GH_TOKEN=
ROSS_GITHUB_TOKEN=
ROSS_PERSONAL_GH_TOKEN=
JOANNE_GITHUB_TOKEN=
ALEX_GITHUB_TOKEN=
GARTH_GITHUB_TOKEN=
TIM_GITHUB_TOKEN=
ANNA_GITHUB_TOKEN=

# Google Docs — create-google-doc (employee override then global)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
JOANNE_GOOGLE_CLIENT_ID=
JOANNE_GOOGLE_CLIENT_SECRET=
JOANNE_GOOGLE_REFRESH_TOKEN=
# Gmail From — create-email (must match Gmail OAuth identity)
JOANNE_GOOGLE_SENDER_EMAIL=
GOOGLE_SENDER_EMAIL=
