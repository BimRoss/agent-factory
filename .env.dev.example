# Core paths
SHARED_CONTRACTS_DIR=/workspace/shared-contracts
SKILL_FACTORY_DIR=/workspace/skill-factory
SKILL_TOOL_SPECS_DIR=/workspace/skill-factory/tools/v1
MEMORY_BANK_FILE=/workspace/shared-contracts/memory-bank.v1.json
AGENT_FACTORY_MODE=serve
EMPLOYEE_ID=joanne

# Gemini (default provider)
INFERENCE_PROVIDER=gemini
# Prefer preview Flash for latency/cost; use gemini-2.5-pro only if you need Pro-only behavior. Google Search grounding works with Flash + GEMINI_ENABLE_WEB_RESEARCH=true.
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_API_KEY=replace-with-dev-default-key
BYOK_GEMINI_API_KEY=
GEMINI_ENABLE_WEB_RESEARCH=true
# Optional: raise if you see empty replies with finishReason=MAX_TOKENS (thinking/search can consume budget before visible text).
# GEMINI_CONV_MAX_OUTPUT_TOKENS=768
# GEMINI_CONV_MAX_OUTPUT_TOKENS_WITH_SEARCH=4096

# Orchestrator + backend endpoints
ORCHESTRATOR_NATS_URL=nats://nats:4222
MAKEACOMPANY_BACKEND_BASE_URL=http://host.docker.internal:8081

# Shared runtime wiring
NATS_URL=nats://nats:4222
NATS_STREAM=SLACK_WORK
NATS_FETCH_BATCH=8
NATS_FETCH_MAX_WAIT_MS=5000
ORCHESTRATOR_INGRESS_WORKERS=4
# Remote handoff (Joanne → Ross on separate pods): Redis stores continuation payload; omit REDIS_URL for in-process handoff only.
# With docker-compose.core.yml use the bundled redis service:
REDIS_URL=redis://redis:6379/0
HANDOFF_REDIS_TTL_SEC=86400
HANDOFF_REDIS_KEY_PREFIX=
BACKEND_INTERNAL_SERVICE_TOKEN=replace-with-dev-internal-token
JOANNE_NATS_DURABLE_NAME=agent-factory-joanne
ROSS_NATS_DURABLE_NAME=agent-factory-ross

# Orchestrator app tokens (slack-orchestrator service)
ORCHESTRATOR_SLACK_BOT_TOKEN=replace-with-orchestrator-bot-token
ORCHESTRATOR_SLACK_APP_TOKEN=replace-with-orchestrator-app-token
MULTIAGENT_BOT_USER_IDS=joanne=UXXXXXX,ross=UYYYYYY
ORCHESTRATOR_TOOL_INTENT_ROUTING_ENABLED=true

# Employee app tokens (agent-factory instances)
JOANNE_SLACK_BOT_TOKEN=replace-with-joanne-bot-token
JOANNE_SLACK_APP_TOKEN=replace-with-joanne-app-token
# Duplicate into agent-joanne compose so handoff replies (e.g. create-issue) can post as Ross.
ROSS_SLACK_BOT_TOKEN=replace-with-ross-bot-token
ROSS_SLACK_APP_TOKEN=replace-with-ross-app-token

# Shared signing secret (or per-app if you split it)
SLACK_SIGNING_SECRET=replace-with-signing-secret

# GitHub — create-issue (matches employee-factory: global or per-employee override)
# Prefer ROSS_GITHUB_* for the Ross agent; falls back to GITHUB_*.
# Internal handoff still executes on the original agent container (e.g. Joanne → Ross runs inside Joanne’s pod), so set shared GITHUB_TOKEN or inject ROSS_GITHUB_* into that service too — see docker-compose agent-joanne.
GITHUB_TOKEN=
GITHUB_OWNER=BimRoss
GITHUB_REPO=create-issue
ROSS_GITHUB_TOKEN=
ROSS_GITHUB_OWNER=
ROSS_GITHUB_REPO=
JOANNE_GITHUB_TOKEN=
JOANNE_GITHUB_OWNER=
JOANNE_GITHUB_REPO=
