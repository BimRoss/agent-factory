# Source-of-truth contracts and tool specs
SHARED_CONTRACTS_DIR=/workspace/shared-contracts
SKILL_FACTORY_DIR=/workspace/skill-factory
SKILL_TOOL_SPECS_DIR=/workspace/skill-factory/tools/v1
MEMORY_BANK_FILE=/workspace/shared-contracts/memory-bank.v1.json
AGENT_FACTORY_MODE=serve
EMPLOYEE_ID=joanne

# Inference provider (Gemini only in this implementation)
INFERENCE_PROVIDER=gemini
# Flash preview aligns with employee-factory OpenRouter default; Pro optional. Search grounding: leave GEMINI_ENABLE_WEB_RESEARCH=true.
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_API_KEY=replace-with-default-platform-key
# Optional BYOK override (takes precedence when set)
BYOK_GEMINI_API_KEY=
GEMINI_ENABLE_WEB_RESEARCH=true
# Optional output ceilings for generateContent (defaults are set in code—raise if replies are empty with MAX_TOKENS).
# GEMINI_CONV_MAX_OUTPUT_TOKENS=768
# GEMINI_CONV_MAX_OUTPUT_TOKENS_WITH_SEARCH=4096

# Integration endpoints (set to real values in .env)
ORCHESTRATOR_NATS_URL=nats://localhost:4222
MAKEACOMPANY_BACKEND_BASE_URL=http://localhost:8081

# Slack + orchestrator integration (required for real Slack runtime wiring)
SLACK_BOT_TOKEN=replace-with-bot-token
# Emoji name for “working” reaction on the triggering message (needs reactions:write). Default hourglass_flowing_sand; set to none to disable.
# SLACK_WAITING_REACTION=hourglass_flowing_sand
# Optional: skip auth.test for thread history; same user id as this bot app
# SLACK_BOT_USER_ID=U…
# Cap Runes for conversations.replies transcript merged into conversation memory (default 12000)
# SLACK_THREAD_CONTEXT_MAX_RUNES=12000
# Optional: mrkdwn section + rich_text element chunk size in Unicode scalars (256–3000; Slack max 3000)
# SLACK_RENDER_MRKDWN_MAX_RUNES=3000
# Optional: same sparse *bold* pass as employee-factory slackformat (see SLACK_SPARSE_MRKDWN_EMPHASIS there). Default on.
# SLACK_SPARSE_MRKDWN_EMPHASIS=false
SLACK_APP_TOKEN=replace-with-app-token
SLACK_SIGNING_SECRET=replace-with-signing-secret

# NATS + Redis runtime plumbing
NATS_URL=nats://localhost:4222
NATS_STREAM=SLACK_WORK
NATS_DURABLE_NAME=agent-factory-joanne
NATS_FETCH_BATCH=8
NATS_FETCH_MAX_WAIT_MS=5000
ORCHESTRATOR_INGRESS_WORKERS=4
REDIS_URL=redis://localhost:6379/0

# Internal backend bridge
BACKEND_INTERNAL_SERVICE_TOKEN=replace-with-internal-service-token
